# Supabase (Vite) — copy to `.env` and fill in. Never commit `.env`.
# Dashboard: Project → Settings → API
#   VITE_SUPABASE_URL          = Project URL (https://xxxx.supabase.co)
#   VITE_SUPABASE_PROJECT_ID   = the `xxxx` part of the hostname
#   VITE_SUPABASE_PUBLISHABLE_KEY = "anon" / "public" JWT (eyJ...), not service_role
VITE_SUPABASE_URL=""
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""

# If you use Lovable Cloud, disable it in Lovable (Connectors → Lovable Cloud)
# so it stops overwriting this repo. Then set vite.config.ts fallbacks (optional)
# to the same public URL/key for CI/pages builds without a .env.
#
# Server-side (SQL, not in .env): after migrations, in Supabase SQL as admin:
#   insert into public.app_config (key, value) values
#     ('push_edge_function_url', 'https://YOUR_REF.supabase.co/functions/v1/broadcast-push'),
#     ('push_webhook_secret', 'SAME_AS_EDGE_SECRET_PUSH_WEBHOOK_SECRET'),
#     ('photo_drive_folder_id', 'GOOGLE_DRIVE_FOLDER_ID_FROM_URL')
#   on conflict (key) do update set value = excluded.value, updated_at = now();
#
# Edge Function secrets you must set (Supabase Dashboard → Edge Functions → Secrets):
#   PUSH_WEBHOOK_SECRET            same value as app_config.push_webhook_secret
#   FIREBASE_SERVICE_ACCOUNT_JSON  Firebase service account JSON (for push)
#   GOOGLE_SERVICE_ACCOUNT_JSON    Google Cloud service account JSON with Drive
#                                  access. Share the target Drive folder with
#                                  the account's client_email as Editor / Content
#                                  manager so submit-photo can upload to it.

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Supabase CLI
supabase/.temp/

# Secrets / env
.env
.env.*
!.env.example
android/app/google-services.json
ios/App/App/GoogleService-Info.plist

# Android (Capacitor) — machine-local / generated
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/local.properties
android/captures/
android/.externalNativeBuild/
android/.cxx/
# Web assets are copied in by `npx cap sync` — regenerated, don't commit
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json
# Release signing — never commit
android/keystore.properties
android/*.keystore
android/*.jks
# Cordova plugin build output (regenerated by cap sync)
android/capacitor-cordova-android-plugins/build/

# iOS (Capacitor) — machine-local / generated
ios/App/build/
ios/App/Pods/
ios/App/Podfile.lock
ios/App/App/public/
ios/DerivedData/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/App/App.xcworkspace/xcuserdata/
# iOS signing — never commit
ios/App/ExportOptions.plist
ios/*.mobileprovision
ios/*.p8
ios/*.p12

# Store assets (keep icons, ignore screenshots)
store-assets/screenshots/
